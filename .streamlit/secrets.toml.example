# .streamlit/secrets.toml.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .streamlit/secrets.toml for LOCAL development.
# On Streamlit Community Cloud, paste these values into:
#   App settings → Secrets (do NOT commit the real secrets.toml to git).
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — enables the OpenAI backend on the AI Summarizer page
OPENAI_API_KEY = "sk-..."

# Anthropic — enables the Anthropic (Claude) backend on the AI Summarizer page
ANTHROPIC_API_KEY = "sk-ant-..."
