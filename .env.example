# =============================================================================
# Dark Web Threat Intelligence Toolkit — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# ── NVD API Key (optional — increases rate limit from 5 to 50 req/30s) ──────
NVD_API_KEY=

# ── AlienVault OTX API Key ──────────────────────────────────────────────────
OTX_API_KEY=

# ── OpenAI API Key (for AI Summarizer module) ───────────────────────────────
OPENAI_API_KEY=

# ── Anthropic API Key (for AI Summarizer module — Claude backend) ────────────
ANTHROPIC_API_KEY=

# ── Proxy Settings (override config/settings.yaml if set) ───────────────────
HTTP_PROXY=
HTTPS_PROXY=
SOCKS5_PROXY=

# ── Log Level Override ──────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Database Path Override ──────────────────────────────────────────────────
DATABASE_PATH=data/threat_intel.db
